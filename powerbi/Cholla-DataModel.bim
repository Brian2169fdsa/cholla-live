          { "name": "LastUpdated", "dataType": "dateTime", "sourceColumn": "LastUpdated" }
        ],
        "partitions": [
          {
            "name": "CensusTracker",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let Source = SharePoint.Tables(\"https://chollabehavioralhealth.sharepoint.com/sites/iop-hub-dev\", [Implementation=\"2.0\"]), CensusTracker = Source{[Title=\"Census Tracker\"]}[Items] in CensusTracker"
            }
          }
        ]
      },
